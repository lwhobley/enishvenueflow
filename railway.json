{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile --prod=false && pnpm run build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/db run push && node --enable-source-maps artifacts/api-server/dist/index.mjs",    "healthcheckPath": "/api/healthz",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
