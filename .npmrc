auto-install-peers=false
strict-peer-dependencies=false

# Always install devDependencies, even when NODE_ENV=production. Railway /
# Nixpacks set NODE_ENV=production for the build phase, which makes pnpm
# strip devDeps by default — but vite, tsc, esbuild and friends live in
# devDeps and are required to PRODUCE the bundled output. Setting
# prod=false here forces pnpm to install everything regardless of the
# environment variable, so the build always has its toolchain. Runtime
# doesn't reinstall so this has no effect at server start.
prod=false
