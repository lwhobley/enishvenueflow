# ─────────────────────────────────────────────────────────────────────────────
# VenueFlow — example environment configuration
#
# Copy to `.env` for local development (`.env` is gitignored), or paste each
# variable into Railway → service → Variables for production. The api-server
# reads these at boot; the frontend doesn't need any of them — its build
# output is static.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Required ────────────────────────────────────────────────────────────────

# Postgres connection string. Railway's Postgres plugin auto-injects this.
DATABASE_URL=postgres://user:password@host:5432/venueflow

# Express session cookies / report-send signing. 32+ random chars.
SESSION_SECRET=replace-with-random-string

# PIN hashing pepper. Combined with a deterministic per-deploy salt before
# scrypt. ≥16 chars, ideally 32+ random. NEVER rotate — every PIN that has
# already been migrated to scrypt format becomes unverifiable if you do.
# Generate with:  node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
PIN_PEPPER=replace-with-random-string-at-least-16-chars

# ─── HTTP port (Railway sets automatically) ──────────────────────────────────
PORT=8080

# ─── Optional: Web Push (for notifications) ──────────────────────────────────
# Generate a keypair with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@enishusa.com

# ─── Optional: Outlook / Microsoft Graph (for end-of-shift email reports) ───
# Without this, /api/reports/*/send returns 412.
OUTLOOK_ACCESS_TOKEN=

# ─── Optional: Gemini (powers the dashboard Cosmic Insights widget) ─────────
# Without this the widget falls back to a small set of curated insights.
# AI_INTEGRATIONS_GEMINI_BASE_URL is a holdover from the Replit proxy; only
# set it if you're routing Gemini through a custom endpoint. Otherwise leave
# blank and the API call goes directly to generativelanguage.googleapis.com.
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# ─── Optional: ADP integration (timeclock sync) ──────────────────────────────
# Without these, time-clock entries get adpSyncStatus="skipped" and the
# scheduler never tries to push them.
ADP_BASE_URL=
ADP_CLIENT_ID=
ADP_CLIENT_SECRET=
ADP_CERT_PATH=
ADP_KEY_PATH=

# ─── Optional: CORS allow-list ──────────────────────────────────────────────
# Comma-separated list of origins allowed to call /api/* cross-origin. Only
# matters when serving the frontend from a different host than the API
# (e.g. running `pnpm --filter @workspace/venueflow run dev` against a
# deployed API). When unset:
#   - dev (NODE_ENV != production): permissive, all origins allowed
#   - prod: cors() not applied at all (API + frontend share origin on Railway)
CORS_ALLOWED_ORIGINS=

# ─── Optional: hires loader target ───────────────────────────────────────────
# By default the api-server runs loadHires() on startup and applies the
# roster to the first active venue. Set this to pin it to a specific
# venue id (useful in multi-venue deployments).
HIRES_VENUE_ID=

# ─── Optional: static frontend dir ───────────────────────────────────────────
# The api-server serves the built frontend from artifacts/venueflow/dist/public
# by default. Override only if the bundle lives elsewhere.
STATIC_DIR=

# ─── Build (set automatically by Railway / Nixpacks; here for reference) ────
NODE_ENV=development
RAILWAY_GIT_COMMIT_SHA=
